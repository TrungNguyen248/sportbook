---
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro'

const { title } = Astro.props;
---
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SportBooker Pro</title>
  </head>
  <body class="bg-zinc-50 min-h-screen flex flex-col font-sans text-zinc-900 selection:bg-emerald-500 selection:text-white">
    <header class="bg-zinc-900 text-white shadow-xl sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 h-18 flex justify-between items-center py-4">
        <a href="/" class="text-2xl font-black text-emerald-400 tracking-tighter uppercase flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          SPORTBOOKER
        </a>
        
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="text-sm font-bold text-zinc-300 hover:text-emerald-400 transition-colors uppercase tracking-wider">Trang chủ</a>
          <a href="/lich-da-dat" class="text-sm font-bold text-zinc-300 hover:text-emerald-400 transition-colors uppercase tracking-wider">Quản lý lịch</a>
          <div class="flex items-center gap-2 bg-emerald-500/10 px-5 py-2.5 rounded-none border border-emerald-500 text-emerald-400 text-sm font-bold tracking-wider">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            HOTLINE: 1900 1000
          </div>
        </nav>

        <button id="mobile-menu-btn" class="md:hidden text-zinc-300 hover:text-emerald-400 focus:outline-none p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="square" stroke-linejoin="miter" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-zinc-800 border-t border-zinc-700">
        <nav class="flex flex-col px-4 py-5 space-y-5 text-center">
          <a href="/" class="text-base font-black text-zinc-300 hover:text-emerald-400 uppercase tracking-widest block transition-colors">Trang chủ</a>
          <a href="/lich-da-dat" class="text-base font-black text-zinc-300 hover:text-emerald-400 uppercase tracking-widest block transition-colors">Quản lý lịch đã đặt</a>
          <div class="flex justify-center mt-2">
            <div class="flex items-center gap-2 bg-emerald-500/10 px-5 py-3 border border-emerald-500 text-emerald-400 text-sm font-black tracking-widest w-fit">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              1900 1000
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow max-w-7xl mx-auto px-4 py-8 md:py-10 w-full">
      <slot />
      <Analytics/>
    </main>

    <footer class="bg-zinc-950 text-zinc-400 py-12 border-t border-zinc-800">
      <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <h3 class="text-xl font-black text-white mb-4 uppercase tracking-wider">SportBooker Pro</h3>
          <p class="text-sm leading-relaxed font-medium">Nền tảng kết nối hàng trăm sân thể thao trên toàn quốc. Đặt lịch nhanh chóng, chính xác, không lo trùng giờ.</p>
        </div>
        <div>
          <h3 class="text-sm font-black text-zinc-200 mb-4 uppercase tracking-widest">Dành cho chủ sân</h3>
          <p class="text-sm font-medium">Đăng ký tham gia hệ thống để quản lý lịch chuyên nghiệp và tiếp cận hàng ngàn khách hàng.</p>
          <a href="#" class="inline-block mt-3 text-emerald-400 text-sm font-black hover:underline uppercase tracking-wider">Đăng ký đối tác →</a>
        </div>
        <div>
          <h3 class="text-sm font-black text-zinc-200 mb-4 uppercase tracking-widest">Liên hệ</h3>
          <p class="text-sm mb-2 font-medium">Email: contact@sportbooker.pro</p>
          <p class="text-sm mb-2 font-medium">Zalo CSKH: 0987.654.321</p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-4 mt-10 pt-6 border-t border-zinc-900 text-center text-xs font-bold text-zinc-600 uppercase tracking-widest">
        © 2026 SportBooker. All rights reserved.
      </div>
    </footer>

    <script>
      // Đợi DOM load xong để gắn sự kiện
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        if (btn && menu) {
          btn.addEventListener('click', () => {
            // Chuyển đổi class 'hidden' để hiện/ẩn menu
            menu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>