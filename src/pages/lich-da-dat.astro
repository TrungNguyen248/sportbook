---
import MainLayout from '../layouts/MainLayout.astro';
import BookedList from '../components/BookedList.jsx';
---

<MainLayout title="Lịch đã đặt">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Quản lý lịch đặt của bạn</h1>
    <p class="text-gray-600 mt-2">Danh sách các sân thể thao bạn đã đặt.</p>
  </div>

  <BookedList client:only="react" />
  
  <div class="mt-8 text-center">
    <a href="/" class="text-gray-600 hover:underline font-medium">← Đặt thêm sân khác</a>
  </div>
</MainLayout>