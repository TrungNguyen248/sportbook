---
import MainLayout from '../../layouts/MainLayout.astro';
import ScheduleManager from '../../components/ScheduleManager.jsx';
import { courts, regions } from '../../data/mockData';

export function getStaticPaths() {
  return courts.map(court => ({
    params: { id: court.id },
    props: { court },
  }));
}

const { court } = Astro.props;
const regionInfo = regions.find(r => r.id === court.regionId);

// Format tiền tệ
const formatPrice = (price) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);

// Tạo URL mã hóa địa chỉ để dùng cho Google Maps
const mapQuery = encodeURIComponent(court.address);
const mapIframeUrl = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const mapExternalUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---

<MainLayout title={court.name}>
  <div class="mb-6">
    <a href="/" class="text-zinc-500 hover:text-emerald-600 font-bold text-sm uppercase tracking-wider flex items-center gap-1 inline-flex transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      TRỞ VỀ DANH SÁCH
    </a>
  </div>
  
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <div class="lg:col-span-4 space-y-6">
      
      <div class="bg-white border border-zinc-200 overflow-hidden shadow-sm">
        <div class="relative h-64">
          <img src={court.image} alt={court.name} class="w-full h-full object-cover" />
          <div class="absolute top-4 left-4 bg-zinc-900 text-white text-xs font-black px-3 py-1.5 uppercase tracking-wider">
            {court.type}
          </div>
        </div>
        
        <div class="p-6">
          <h1 class="text-2xl lg:text-3xl font-black text-zinc-900 mb-4 leading-tight uppercase tracking-tight">{court.name}</h1>
          
          <div class="space-y-4 text-sm font-medium text-zinc-600 border-t border-zinc-100 pt-4">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{court.address} <br/> <span class="text-xs text-zinc-400 font-bold tracking-wider uppercase">({regionInfo?.name})</span></span>
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              <span class="text-xl font-black text-zinc-900">{formatPrice(court.price)} <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest">/ GIỜ</span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white border border-zinc-200 shadow-sm p-1">
        <div class="w-full h-48 bg-zinc-100 overflow-hidden">
          <iframe 
            src={mapIframeUrl} 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <a href={mapExternalUrl} target="_blank" rel="noopener noreferrer" 
           class="mt-1 flex items-center justify-center w-full bg-zinc-50 hover:bg-emerald-50 text-zinc-900 hover:text-emerald-700 font-black uppercase tracking-wider py-3.5 transition-colors border border-transparent hover:border-emerald-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
          MỞ TRÊN GOOGLE MAPS
        </a>
      </div>

      <div class="bg-zinc-900 text-white p-6 border-l-4 border-emerald-500 shadow-sm">
        <h3 class="text-xs font-black text-zinc-400 uppercase tracking-widest mb-4">THÔNG TIN CHỦ SÂN</h3>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-emerald-500 rounded-none flex items-center justify-center text-white text-xl font-black">
            {court.ownerName.charAt(0)}
          </div>
          <div>
            <p class="font-black text-lg tracking-wide uppercase">{court.ownerName}</p>
            <a href={`tel:${court.ownerPhone}`} class="text-emerald-400 text-base font-bold hover:underline flex items-center mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {court.ownerPhone}
            </a>
          </div>
        </div>
      </div>
      
    </div>

    <div class="lg:col-span-8">
      <ScheduleManager client:load court={court} />
    </div>
  </div>
</MainLayout>